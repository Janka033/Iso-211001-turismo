# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
# service_role: SOLO para seed y provisioning en signup. Salta RLS — no usar en el flujo normal.
SUPABASE_SERVICE_ROLE_KEY=
# Secreto para verificar el JWT (proyectos legacy HS256). Si el proyecto usa JWKS asimétrico,
# deja esto vacío y rellena SUPABASE_JWKS_URL.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_JWKS_URL=
# Audiencia esperada del JWT de Supabase
SUPABASE_JWT_AUDIENCE=authenticated

# IA
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# gemini-embedding-001 con output_dimensionality=768 (text-embedding-004 fue retirado en 2026)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
